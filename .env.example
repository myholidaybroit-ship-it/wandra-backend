# ── Wandra backend environment ─────────────────────────────────────────────
# Copy this file to `.env` and fill in real values. `.env` is gitignored.

# MongoDB Atlas connection string (SRV). Create a free cluster at
# https://cloud.mongodb.com, add a database user, allow your IP, then paste the
# "Connect your application" string here. Keep the db name as `wandra`.
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.xxxxx.mongodb.net/wandra?retryWrites=true&w=majority

# JWT signing — use long random strings (e.g. `openssl rand -hex 48`)
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Server
PORT=4000
NODE_ENV=development

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5281

# ── AWS S3 storage (file/image uploads) ────────────────────────────────────
# Uploaded logos, photos, client docs, payment proofs & story images are stored
# in this bucket; the app saves the returned public URL. If these are blank,
# uploads gracefully fall back to inline data-URLs (no cloud storage).
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_REGION=ap-south-1
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_SES_ACCESS_KEY_ID=your-ses-access-key-id
S3_BUCKET=your-bucket-name
S3_PUBLIC_BASE_URL=https://your-bucket-name.s3.ap-south-1.amazonaws.com
S3_UPLOAD_PREFIX=myholidaybro

# ── Admin panel login (super admin) ────────────────────────────────────────
# These ARE the admin-panel credentials — the login validates directly against
# them. Change them here and restart the backend to change the admin login.
# (The agency/SaaS side uses per-agency accounts managed in the admin UI, not these.)
SUPER_ADMIN_EMAIL=admin@wandra.travel
SUPER_ADMIN_PASSWORD=wandra@admin
